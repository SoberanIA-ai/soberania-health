.DS_Store
Thumbs.db

# Data — nunca commitear datos reales o backups locales
# Los códigos REALES de aseguradoras vienen de HM en Fase 0; jamás en git.
# Los casos_test/ son inputs sintéticos para tests, sí van en git.
data/codigos/*.json
!data/codigos/.gitkeep
*.db
*.sqlite
*.sqlite3

# Docker volumes
postgres_data/

# Logs
*.log
logs/

# Alembic — mantener migraciones en git, ignorar caches
alembic/__pycache__/

# Streamlit
.streamlit/secrets.toml

# Playwright
playwright-report/
test-results/

# Perfiles y credenciales de demo — nunca subir al repo
PERFILES_DEMO.md

# Frontend Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
