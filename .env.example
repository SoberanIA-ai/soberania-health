# Entorno: "development" | "production"
# En "production" la app no arranca si JWT_SECRET_KEY o DATABASE_URL
# siguen con los valores de demo de este fichero (ver app/config.py).
ENVIRONMENT=development

# LLM — API Mistral (NO self-hosted en MVP)
# Dejar vacío para mock mode determinístico (regla 5 sec 19).
# Para modo real, pegar la API key real.
MISTRAL_API_KEY=

# Base de datos
DATABASE_URL=postgresql://soberania:soberania@localhost:5432/health
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Observabilidad — dejar vacío si no usas Langfuse en local
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Agente
CONFIDENCE_THRESHOLD_HITL=0.80
MODO_DEFAULT=mock
# Seed determinístico del MockConnector para que la demo sea reproducible.
# Quitar (= vacío) para comportamiento aleatorio 80/15/5.
MOCK_CONNECTOR_SEED=42

# Notificaciones
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=health@soberania.eu

# Compliance
AUDIT_LOG_ENABLED=true
HITL_OBLIGATORIO_MODO_REAL=true

# Auth JWT
JWT_SECRET_KEY=CAMBIAR-EN-PRODUCCION-clave-secreta-soberania-health-2026
JWT_EXPIRE_MINUTES=480

# Conectores aseguradoras (solo para modo real)
SANITAS_PORTAL_URL=
SANITAS_USER=
SANITAS_PASSWORD=
ADESLAS_PORTAL_URL=
ADESLAS_USER=
ADESLAS_PASSWORD=
DKV_PORTAL_URL=
DKV_USER=
DKV_PASSWORD=
